# ======================================
#  Configuración del entorno - CineClub Salamanca
# ======================================
# Copiar como .env y ajustar los valores. El archivo .env NO se versiona.

# Base de datos PostgreSQL
POSTGRES_DB=cineclub
POSTGRES_USER=cineclub_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_PORT=5432
# Host de la base de datos (solo perfil prod). En Docker Compose es el nombre del servicio.
POSTGRES_HOST=db
# Tamaño máximo del pool de conexiones (solo perfil prod)
DB_POOL_MAX=10

# JWT
# Debe tener al menos 256 bits (32 caracteres). Generar uno único por entorno:
#   openssl rand -base64 48
JWT_SECRET=your_super_secret_key_with_at_least_256_bits_of_length
JWT_EXPIRATION_MS=86400000

# Server
SERVER_PORT=8080
FRONTEND_PORT=3000

# Logging
# Niveles: TRACE, DEBUG, INFO, WARN, ERROR. Usar INFO en producción.
LOG_LEVEL=DEBUG
LOG_PATH=./logs

# Mantenimiento
# Meses que se conservan las reservas de funciones pasadas antes de purgarlas
RETENCION_MESES=12
# Días que se conservan los respaldos de la base de datos
RETENCION_DIAS=30

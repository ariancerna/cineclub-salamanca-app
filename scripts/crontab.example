# ==========================================================================
#  CineClub Salamanca — Cron jobs del sistema operativo (servidor Linux)
# --------------------------------------------------------------------------
#  Instalar con:  crontab scripts/crontab.example
#  Verificar con: crontab -l
#
#  Nota: las tareas de LOGICA DE NEGOCIO (reporte diario, auditoria de aforo,
#  purga de reservas) NO viven aqui: se ejecutan dentro de la aplicacion con
#  @Scheduled (ver TareasMantenimiento.java), porque necesitan acceso al
#  modelo de dominio y a las transacciones de JPA.
#
#  Este crontab cubre las tareas de INFRAESTRUCTURA, que deben sobrevivir
#  aunque la aplicacion este caida.
# ==========================================================================

SHELL=/bin/bash
PATH=/usr/local/bin:/usr/bin:/bin
PROYECTO=/opt/cineclub-salamanca
MAILTO=admin@cineclub.com

# --- Respaldo diario de la base de datos (02:00) ---
0 2 * * * cd $PROYECTO && ./scripts/backup.sh >> /var/log/cineclub/backup.log 2>&1

# --- Verificacion de salud cada 5 minutos ---
*/5 * * * * cd $PROYECTO && ./scripts/healthcheck.sh >> /var/log/cineclub/health.log 2>&1

# --- Prueba mensual de restauracion sobre base de ensayo (dia 15, 05:00) ---
# Un respaldo que nunca se restaura no es un respaldo: se valida cada mes.
0 5 15 * * cd $PROYECTO && CONTENEDOR_DB=cineclub-db-ensayo ./scripts/restore.sh --ultimo >> /var/log/cineclub/restore-test.log 2>&1

# --- Limpieza de logs rotados con mas de 90 dias (domingos, 04:30) ---
# Logback ya rota y comprime; esta tarea es la red de seguridad del sistema de archivos.
30 4 * * 0 find $PROYECTO/logs -name '*.log.gz' -mtime +90 -delete

# --- Poda de imagenes y volumenes Docker huerfanos (domingos, 05:30) ---
30 5 * * 0 docker system prune -f --filter "until=720h" >> /var/log/cineclub/docker-prune.log 2>&1
